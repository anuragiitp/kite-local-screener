{
  "manifest_version": 3,
  "name": "Kite Local Screener",
  "version": "1.2.1",
  "description": "Loads the local screener app only at https://kite.zerodha.com/local-screener using your Kite session.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "cookies",
    "storage",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://kite.zerodha.com/*",
    "https://api.kite.trade/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kite.zerodha.com/local-screener*"
      ],
      "js": [
        "local-screener.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Kite Local Screener"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
